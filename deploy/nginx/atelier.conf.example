# Nginx site config for atelier (zhkun.xyz)
# Copy to /etc/nginx/conf.d/atelier.conf and adjust server_name / SSL paths.
#
# Prerequisites:
#   limit_req_zone / limit_conn_zone in http {} block (see deploy/nginx/nginx-http-snippet.conf)

upstream atelier_backend {
    server 127.0.0.1:8000;
    keepalive 16;
}

server {
    listen 80;
    listen [::]:80;
    server_name zhkun.xyz www.zhkun.xyz;

    # certbot will add HTTPS redirect; after certbot, duplicate this server {} for 443 ssl

    client_max_body_size 1m;

    # Security headers (app layer also sets these; nginx as fallback)
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    location /static/ {
        limit_req zone=atelier_static burst=40 nodelay;
        limit_conn atelier_conn 20;

        proxy_pass http://atelier_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 10s;
        proxy_read_timeout 60s;
    }

    location /wallpaper/ {
        limit_req zone=atelier_heavy burst=15 nodelay;
        limit_conn atelier_conn 10;

        proxy_pass http://atelier_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 10s;
        proxy_read_timeout 120s;
        proxy_buffering on;
    }

    location / {
        limit_req zone=atelier_general burst=30 nodelay;
        limit_conn atelier_conn 25;

        proxy_pass http://atelier_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 10s;
        proxy_read_timeout 30s;
        proxy_send_timeout 30s;
    }
}
